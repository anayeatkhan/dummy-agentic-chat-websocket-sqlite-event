# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  copy to .env and fill in your values
#
# For local dev with docker-compose, these are already set in docker-compose.yml.
# For running services directly (python -m uvicorn ...) copy this file to .env
# and source it: `source .env` or use python-dotenv.
# ─────────────────────────────────────────────────────────────────────────────

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id

# ── Pub/Sub ───────────────────────────────────────────────────────────────────
PUBSUB_TOPIC_ID=chat-events
PUBSUB_SUBSCRIPTION_ID=chat-events-sub

# Uncomment to use the local Pub/Sub emulator instead of real GCP:
# PUBSUB_EMULATOR_HOST=localhost:8085

# ── Cloud SQL / PostgreSQL ────────────────────────────────────────────────────
# Local dev (Docker Compose or direct postgres):
DATABASE_URL=postgresql://chatuser:chatpass@localhost:5432/chatdb

# Cloud Run with Cloud SQL Auth Proxy (Unix socket):
# DATABASE_URL=postgresql://chatuser:chatpass@/chatdb?host=/cloudsql/PROJECT:REGION:INSTANCE

# ── Redis (Cloud Memorystore) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# How long (seconds) to keep a streaming buffer key in Redis before auto-expiry.
# Should be longer than your longest expected LLM response time.
STREAM_BUFFER_TTL=300

# ── GCP Authentication ────────────────────────────────────────────────────────
# On Cloud Run: Application Default Credentials are automatic — no config needed.
# Local dev with real GCP (not emulator):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
